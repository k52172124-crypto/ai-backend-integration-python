# OpenAI 인증 — 실제 키로 교체 후 .env로 복사
OPENAI_API_KEY=sk-...

# 사용 모델 (기본값 권장)
MODEL_NAME=gpt-5-nano

# 서버 포트 (기본 8000)
PORT=8000

# OpenAI 호출 타임아웃 초 (기본 30)
REQUEST_TIMEOUT=30

# --- RAG 설정 ---
# 임베딩 모델 (인제스트/검색이 동일해야 함)
EMBEDDING_MODEL=text-embedding-3-small
# 벡터 DB 저장 경로 (POST /ingest 가 생성)
CHROMA_DIR=./chroma_db
# 검색 시 가져올 청크 수
RAG_TOP_K=3
# 청킹 크기/겹침
CHUNK_SIZE=500
CHUNK_OVERLAP=50
